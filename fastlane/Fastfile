opt_out_usage

default_platform(:android)

ANDROID_PACKAGE_NAME = "com.thecodegrove.grovetimer"
RELEASE_AAB_PATH = "app/build/outputs/bundle/release/app-release.aab"
PLAY_METADATA_PATH = "fastlane/metadata/android"

def google_play_auth_options
  if ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"].to_s.strip.length > 0
    { json_key_data: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"] }
  elsif ENV["GOOGLE_PLAY_JSON_KEY_FILE"].to_s.strip.length > 0
    { json_key: ENV["GOOGLE_PLAY_JSON_KEY_FILE"] }
  elsif ENV["GOOGLE_APPLICATION_CREDENTIALS"].to_s.strip.length > 0
    {}
  else
    UI.user_error!("Set GOOGLE_PLAY_SERVICE_ACCOUNT_JSON, GOOGLE_PLAY_JSON_KEY_FILE, or authenticate with Application Default Credentials before uploading to Google Play.")
  end
end

platform :android do
  desc "Build the signed release Android App Bundle"
  lane :build_release do
    gradle(task: "clean")
    gradle(task: "bundle", build_type: "Release")
  end

  desc "Validate a Google Play upload without committing the edit"
  lane :validate_play do |options|
    build_release

    upload_to_play_store(
      google_play_auth_options.merge(
        package_name: ANDROID_PACKAGE_NAME,
        aab: RELEASE_AAB_PATH,
        metadata_path: PLAY_METADATA_PATH,
        track: options[:track] || ENV.fetch("PLAY_TRACK", "internal"),
        release_status: options[:release_status] || ENV.fetch("PLAY_RELEASE_STATUS", "draft"),
        validate_only: true,
        skip_upload_changelogs: true,
        ack_bundle_installation_warning: true
      )
    )
  end

  desc "Upload the signed release AAB to Google Play, defaulting to the internal track as a draft"
  lane :play_internal do |options|
    build_release

    upload_to_play_store(
      google_play_auth_options.merge(
        package_name: ANDROID_PACKAGE_NAME,
        aab: RELEASE_AAB_PATH,
        track: options[:track] || ENV.fetch("PLAY_TRACK", "internal"),
        release_status: options[:release_status] || ENV.fetch("PLAY_RELEASE_STATUS", "draft"),
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: true,
        skip_upload_changelogs: true,
        ack_bundle_installation_warning: true
      )
    )
  end

  desc "Upload only Google Play Store listing metadata, images, and screenshots"
  lane :play_metadata do |options|
    upload_to_play_store(
      google_play_auth_options.merge(
        package_name: ANDROID_PACKAGE_NAME,
        metadata_path: PLAY_METADATA_PATH,
        skip_upload_apk: true,
        skip_upload_aab: true,
        skip_upload_changelogs: true,
        validate_only: options[:validate_only] || ENV.fetch("PLAY_VALIDATE_ONLY", "false") == "true"
      )
    )
  end

  desc "Upload the internal track AAB together with Play Store listing assets"
  lane :play_internal_with_metadata do |options|
    build_release

    upload_to_play_store(
      google_play_auth_options.merge(
        package_name: ANDROID_PACKAGE_NAME,
        metadata_path: PLAY_METADATA_PATH,
        aab: RELEASE_AAB_PATH,
        track: options[:track] || ENV.fetch("PLAY_TRACK", "internal"),
        release_status: options[:release_status] || ENV.fetch("PLAY_RELEASE_STATUS", "draft"),
        skip_upload_changelogs: true,
        ack_bundle_installation_warning: true
      )
    )
  end
end
