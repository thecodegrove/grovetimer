    <!-- Permissions -->
    <string name="permissions_required_title">Permisos Necessaris</string>
    <string name="permissions_required_description">GroveTimer necessita els següents permisos per pausar automàticament la reproducció de mitjans quan el temporitzador acabi. Tots els permisos són necessaris per al correcte funcionament de l\'aplicació.</string>
    <string name="permissions_denied_title">Permisos Denegats</string>
    <string name="permissions_denied_description">Alguns permisos han estat denegats. Pots habilitar-los manualment a la configuració de l\'aplicació.</string>
    <string name="open_settings_button">Obrir Configuració</string>
    
    <!-- Permission Titles -->
    <string name="permission_vibrate_title">Permís de Vibració</string>
    <string name="permission_notifications_title">Permís de Notificacions</string>
    
    <!-- Permission Descriptions -->
    <string name="permission_vibrate_description">GroveTimer necessita el permís de vibració per notificar-te quan el temporitzador acabi. Si has activat l\'opció \"Vibrar quan acabi\" a la configuració, el dispositiu vibrarà suaument quan el temps s\'esgoti, fins i tot si la pantalla està apagada o el dispositiu està en mode silenciós.</string>
    <string name="permission_notifications_description">GroveTimer necessita el permís de notificacions per mostrar-te una notificació persistent mentre el temporitzador està actiu. Aquesta notificació et permet veure el temps restant i pausar o cancel·lar el temporitzador en qualsevol moment, fins i tot quan estàs utilitzant altres aplicacions.</string>
    
    <!-- Notification Listener -->
    <string name="notification_listener_title">Accés a Notificacions del Sistema</string>
    <string name="notification_listener_description">GroveTimer necessita accés a les notificacions del sistema per detectar quina aplicació està reproduint contingut multimèdia (música, podcasts, vídeos, etc.) i poder pausar-la automàticament quan el temporitzador acabi. Aquest accés només s\'utilitza per identificar i controlar la reproducció de mitjans, no s\'accedeix a altres notificacions ni es comparteix informació personal.</string>
    <string name="notification_listener_button">Obrir Ajustos del Sistema</string>
    
    <!-- Notification Dialog -->
    <string name="notification_permission_title">Permís Necessari</string>
    <string name="notification_permission_message">Per permetre que aquesta aplicació pausi altres reproductors multimèdia, si us plau habilita l\'Accés a Notificacions per GroveTimer a la següent pantalla.</string>
