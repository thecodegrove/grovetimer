    <!-- Permission Titles -->
    <string name="permission_vibrate_title">Vibration Permission</string>
    <string name="permission_notifications_title">Notification Permission</string>
    
    <!-- Permission Descriptions -->
    <string name="permission_vibrate_description">GroveTimer needs vibration permission to notify you when the timer ends. If you have enabled the \"Vibrate when finished\" option in settings, the device will vibrate gently when the time runs out, even if the screen is off or the device is in silent mode.</string>
    <string name="permission_notifications_description">GroveTimer needs notification permission to show you a persistent notification while the timer is active. This notification allows you to see the remaining time and pause or cancel the timer at any time, even when you are using other applications.</string>
    
    <!-- Notification Listener -->
    <string name="notification_listener_title">System Notification Access</string>
    <string name="notification_listener_description">GroveTimer needs access to system notifications to detect which application is playing multimedia content (music, podcasts, videos, etc.) and be able to pause it automatically when the timer ends. This access is only used to identify and control media playback, other notifications are not accessed and no personal information is shared.</string>
    <string name="notification_listener_button">Open System Settings</string>
    
