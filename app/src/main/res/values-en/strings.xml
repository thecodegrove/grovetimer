    <!-- Permissions -->
    <string name="permissions_required_title">Required Permissions</string>
    <string name="permissions_required_description">GroveTimer needs the following permissions to automatically pause media playback when the timer ends. All permissions are necessary for the correct functioning of the application.</string>
    <string name="permissions_denied_title">Permissions Denied</string>
    <string name="permissions_denied_description">Some permissions were denied. You can enable them manually in the application settings.</string>
