    <!-- Permissions -->
    <string name="permissions_required_title">Permisos Necesarios</string>
    <string name="permissions_required_description">GroveTimer necesita los siguientes permisos para pausar automáticamente la reproducción de medios cuando el timer termine. Todos los permisos son necesarios para el correcto funcionamiento de la aplicación.</string>
    <string name="permissions_denied_title">Permisos Denegados</string>
    <string name="permissions_denied_description">Algunos permisos fueron denegados. Puedes habilitarlos manualmente en la configuración de la aplicación.</string>
    <string name="open_settings_button">Abrir Configuración</string>
    
    <!-- Permission Titles -->
    <string name="permission_vibrate_title">Permiso de Vibración</string>
    <string name="permission_notifications_title">Permiso de Notificaciones</string>
    
    <!-- Permission Descriptions -->
    <string name="permission_vibrate_description">GroveTimer necesita el permiso de vibración para notificarte cuando el timer termine. Si has activado la opción \"Vibrar al finalizar\" en la configuración, el dispositivo vibrará suavemente cuando el tiempo se agote, incluso si la pantalla está apagada o el dispositivo está en modo silencioso.</string>
    <string name="permission_notifications_description">GroveTimer necesita el permiso de notificaciones para mostrarte una notificación persistente mientras el timer está activo. Esta notificación te permite ver el tiempo restante y pausar o cancelar el timer en cualquier momento, incluso cuando estás usando otras aplicaciones.</string>
    
    <!-- Notification Listener -->
    <string name="notification_listener_title">Acceso a Notificaciones del Sistema</string>
    <string name="notification_listener_description">GroveTimer necesita acceso a las notificaciones del sistema para detectar qué aplicación está reproduciendo contenido multimedia (música, podcasts, videos, etc.) y poder pausarla automáticamente cuando el timer termine. Este acceso solo se usa para identificar y controlar la reproducción de medios, no se accede a otras notificaciones ni se comparte información personal.</string>
    <string name="notification_listener_button">Abrir Ajustes del Sistema</string>
    
    <!-- Notification Dialog -->
    <string name="notification_permission_title">Permiso Necesario</string>
    <string name="notification_permission_message">Para permitir que esta aplicación pause otros reproductores multimedia, por favor habilita el Acceso a Notificaciones para GroveTimer en la siguiente pantalla.</string>
